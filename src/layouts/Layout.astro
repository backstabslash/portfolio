---
import '../styles/global.css';
import ParticleBackground from '../components/ParticleBackground.astro';
import config from '../../site.config';

const { theme } = config;

const themeVars = {
  light: Object.entries(theme.light)
    .map(([key, val]) => {
      const prop = key.replace(/([A-Z])/g, '-$1').toLowerCase();
      return `--${prop}: ${val};`;
    })
    .join('\n    '),
  dark: Object.entries(theme.dark)
    .map(([key, val]) => {
      const prop = key.replace(/([A-Z])/g, '-$1').toLowerCase();
      return `--${prop}: ${val};`;
    })
    .join('\n    '),
};

interface Props {
  title?: string;
  description?: string;
}

const { title = config.name, description = config.bio } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link
      rel="preload"
      href="/fonts/jetbrains-mono-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.site?.toString() || ''} />
    <meta name="twitter:card" content="summary" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style
      set:html={`
      [data-theme='light'] {
        ${themeVars.light}
        --accent: ${theme.colors.accentLight};
      }
      [data-theme='dark'] {
        ${themeVars.dark}
        --accent: ${theme.colors.accentDark};
      }
    `}
    ></style>
    <script
      is:inline
      define:vars={{
        faviconThemes: {
          dark: { bg: theme.dark.bg, accent: theme.colors.accentDark },
          light: { bg: theme.light.bg, accent: theme.colors.accentLight },
        },
      }}
    >
      (function () {
        const stored = localStorage.getItem('theme');
        const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches
          ? 'dark'
          : 'light';
        document.documentElement.setAttribute('data-theme', stored || preferred);

        function faviconSvg(bg, accent, showCursor) {
          var cursor = showCursor
            ? '<rect x="16" y="20" width="10" height="2.5" rx="1.25" fill="' + accent + '"/>'
            : '';
          return (
            'data:image/svg+xml,' +
            encodeURIComponent(
              '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><rect width="32" height="32" rx="6" fill="' +
                bg +
                '"/><path d="M6 11L12 16L6 21" stroke="' +
                accent +
                '" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>' +
                cursor +
                '</svg>',
            )
          );
        }

        var themes = faviconThemes;

        var link = document.querySelector('link[rel="icon"]');
        var visible = true;

        window.__updateFavicon = function () {
          var t = themes[document.documentElement.getAttribute('data-theme') || 'dark'];
          link.href = faviconSvg(t.bg, t.accent, visible);
        };

        window.__updateFavicon();
        setInterval(function () {
          visible = !visible;
          window.__updateFavicon();
        }, 550);
      })();
    </script>
  </head>
  <body>
    <ParticleBackground />
    <div class="content" style="position:relative;z-index:1;">
      <slot />
    </div>
  </body>
</html>
