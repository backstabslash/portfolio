---
import config from '../../site.config';
---

<section id="contact" class="contact">
  <h2>{config.contact.heading}</h2>
  <p>{config.contact.description}</p>
  <div class="contact-links">
    <a href={`mailto:${config.email}`} class="btn-primary">{config.email}</a>
    <a href={config.links.linkedin} target="_blank" rel="noopener noreferrer" class="btn-secondary">
      LinkedIn
    </a>
  </div>
</section>

<style>
  .contact {
    text-align: center;
    padding: 140px 48px;
  }

  .contact h2 {
    font-size: 40px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .contact p {
    color: var(--text-secondary);
    font-size: 16px;
    margin-bottom: 32px;
  }

  .contact-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .contact {
      padding: 80px 24px;
    }

    .contact h2 {
      font-size: 28px;
    }
  }
</style>
