---
import config from '../../site.config';
---

<section id="contact" class="contact">
  <h2>Let's work together</h2>
  <p>Open to DevOps, Developer Experience, and Software Engineering roles.</p>
  <div class="contact-links">
    <a href={`mailto:${config.email}`} class="btn-primary">{config.email}</a>
    <a href={config.links.linkedin} target="_blank" rel="noopener noreferrer" class="btn-secondary">
      LinkedIn
    </a>
  </div>
</section>

<style>
  .contact {
    text-align: center;
    padding: 140px 48px;
  }

  .contact h2 {
    font-size: 40px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .contact p {
    color: var(--text-secondary);
    font-size: 16px;
    margin-bottom: 32px;
  }

  .contact-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 12px 28px;
    background: var(--accent);
    color: var(--bg);
    font-weight: 600;
    font-size: 14px;
    transition: filter 0.2s;
  }

  .btn-primary:hover {
    filter: brightness(1.15);
  }

  .btn-secondary {
    padding: 12px 28px;
    background: transparent;
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 14px;
    border: 1px solid var(--border);
    transition:
      border-color 0.2s,
      color 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--border-hover);
    color: var(--text);
  }

  @media (max-width: 768px) {
    .contact {
      padding: 80px 24px;
    }

    .contact h2 {
      font-size: 28px;
    }
  }
</style>
