---
import config from '../../site.config';
---

<section class="hero">
  <div class="hero-content">
    <div class="hero-text">
      <p class="hero-label">// {config.title}</p>
      <h1 class="hero-headline">{config.headline}</h1>
      <p class="hero-bio">{config.bio}</p>
      <div class="hero-ctas">
        <a href="#contact" class="btn-primary">Get in touch</a>
        <a
          href={config.links.github}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          GitHub
        </a>
      </div>
    </div>
    <div class="hero-image">
      <img src={config.profileImage} alt={config.name} width="220" height="220" />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 100px;
  }

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
  }

  .hero-text {
    flex: 1;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: 20px;
  }

  .hero-headline {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 24px;
    max-width: 800px;
  }

  .hero-bio {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 700px;
    line-height: 1.7;
    margin-bottom: 40px;
    text-align: justify;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .hero-image img {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
  }

  @media (max-width: 768px) {
    .hero-content {
      flex-direction: column-reverse;
      text-align: center;
    }

    .hero-text {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero-headline {
      max-width: 100%;
    }

    .hero-bio {
      max-width: 100%;
      text-align: justify;
    }

    .hero-image img {
      width: 120px;
      height: 120px;
    }
  }
</style>
