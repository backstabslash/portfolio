---

---

<canvas id="particle-canvas" aria-hidden="true"></canvas>

<style>
  #particle-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
  }
</style>

<script is:inline>
  (function () {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const canvas = document.getElementById('particle-canvas');
    if (!canvas || reducedMotion) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    const isMobile = window.innerWidth < 768;
    const DENSITY = isMobile ? 100 : 200;
    const CONNECTION_RADIUS = isMobile ? 80 : 120;
    const REPULSION_RADIUS = 100;
    const MAX_REPULSION_SPEED = 1.5;
    const BUFFER = 150;

    let w = 0;
    let viewH = 0;
    let docH = 0;
    let scrollY = 0;
    const mouse = { x: -1000, y: -1000 };
    const particles = [];

    function getAccentColor() {
      const raw = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim();
      const m = raw.match(/^#([0-9a-f]{2})([0-9a-f]{2})([0-9a-f]{2})$/i);
      if (!m) return { r: 16, g: 185, b: 129 };
      return { r: parseInt(m[1], 16), g: parseInt(m[2], 16), b: parseInt(m[3], 16) };
    }

    let accent = getAccentColor();

    function isDarkTheme() {
      return document.documentElement.getAttribute('data-theme') === 'dark';
    }

    function getDocHeight() {
      return Math.max(
        document.body.scrollHeight,
        document.documentElement.scrollHeight,
        window.innerHeight,
      );
    }

    function particleCount() {
      return Math.round(DENSITY * (docH / window.innerHeight));
    }

    function resize() {
      var oldW = w;
      var oldDocH = docH;
      w = window.innerWidth;
      viewH = window.innerHeight;
      docH = getDocHeight();
      canvas.width = w * dpr;
      canvas.height = viewH * dpr;
      canvas.style.width = w + 'px';
      canvas.style.height = viewH + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      if (oldW > 0 && oldDocH > 0) {
        for (var i = 0; i < particles.length; i++) {
          particles[i].x = (particles[i].x / oldW) * w;
          particles[i].y = (particles[i].y / oldDocH) * docH;
        }
      }

      syncParticleCount();
    }

    function syncParticleCount() {
      var target = particleCount();
      while (particles.length < target) {
        particles.push({
          x: Math.random() * w,
          y: Math.random() * docH,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          r: Math.random() * 1.5 + 0.5,
        });
      }
      if (particles.length > target) {
        particles.length = target;
      }
    }

    function init() {
      resize();
      particles.length = 0;
      var count = particleCount();
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * w,
          y: Math.random() * docH,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          r: Math.random() * 1.5 + 0.5,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, w, viewH);
      scrollY = window.scrollY;
      const dark = isDarkTheme();
      const lineBaseAlpha = dark ? 0.15 : 0.1;
      const dotBaseAlpha = dark ? 0.4 : 0.3;

      var visTop = scrollY - BUFFER;
      var visBot = scrollY + viewH + BUFFER;

      // Mouse position in world space
      var mouseWorldX = mouse.x;
      var mouseWorldY = mouse.y + scrollY;

      // Collect visible particle indices for connection checks
      var visible = [];
      for (let i = 0; i < particles.length; i++) {
        if (particles[i].y >= visTop && particles[i].y <= visBot) {
          visible.push(i);
        }
      }

      // Physics for visible particles only
      for (let vi = 0; vi < visible.length; vi++) {
        const p = particles[visible[vi]];
        const dx = p.x - mouseWorldX;
        const dy = p.y - mouseWorldY;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < REPULSION_RADIUS && dist > 0) {
          const force = ((REPULSION_RADIUS - dist) / REPULSION_RADIUS) * 0.8;
          p.vx += (dx / dist) * force * 0.1;
          p.vy += (dy / dist) * force * 0.1;
        }

        p.vx *= 0.97;
        p.vy *= 0.97;
        const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        if (speed > MAX_REPULSION_SPEED) {
          p.vx = (p.vx / speed) * MAX_REPULSION_SPEED;
          p.vy = (p.vy / speed) * MAX_REPULSION_SPEED;
        }
        p.x += p.vx;
        p.y += p.vy;

        if (p.x < -50) p.x = w + 50;
        if (p.x > w + 50) p.x = -50;
        if (p.y < -50) p.y = docH + 50;
        if (p.y > docH + 50) p.y = -50;
      }

      // Connection lines between visible particles
      for (let i = 0; i < visible.length; i++) {
        for (let j = i + 1; j < visible.length; j++) {
          const a = particles[visible[i]];
          const b = particles[visible[j]];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < CONNECTION_RADIUS) {
            const alpha = (1 - dist / CONNECTION_RADIUS) * lineBaseAlpha;
            ctx.beginPath();
            ctx.strokeStyle =
              'rgba(' + accent.r + ',' + accent.g + ',' + accent.b + ',' + alpha + ')';
            ctx.lineWidth = 0.5;
            ctx.moveTo(a.x, a.y - scrollY);
            ctx.lineTo(b.x, b.y - scrollY);
            ctx.stroke();
          }
        }
      }

      // Draw visible dots
      for (let vi = 0; vi < visible.length; vi++) {
        const p = particles[visible[vi]];
        const screenY = p.y - scrollY;
        const dx = p.x - mouseWorldX;
        const dy = p.y - mouseWorldY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const glow = dist < 200 ? (1 - dist / 200) * 0.5 : 0;

        ctx.beginPath();
        ctx.fillStyle =
          'rgba(' + accent.r + ',' + accent.g + ',' + accent.b + ',' + (dotBaseAlpha + glow) + ')';
        ctx.arc(p.x, screenY, p.r + glow * 2, 0, Math.PI * 2);
        ctx.fill();
      }

      requestAnimationFrame(draw);
    }

    window.addEventListener('resize', resize);
    window.addEventListener('mousemove', function (e) {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    });
    window.addEventListener('touchmove', function (e) {
      if (e.touches.length > 0) {
        mouse.x = e.touches[0].clientX;
        mouse.y = e.touches[0].clientY;
      }
    });
    window.addEventListener('touchend', function () {
      mouse.x = -1000;
      mouse.y = -1000;
    });

    const themeObserver = new MutationObserver(function () {
      accent = getAccentColor();
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });

    // Re-measure doc height when DOM changes (e.g. lazy content)
    const bodyObserver = new ResizeObserver(function () {
      var newDocH = getDocHeight();
      if (newDocH !== docH) {
        var oldDocH = docH;
        docH = newDocH;
        for (var i = 0; i < particles.length; i++) {
          particles[i].y = (particles[i].y / oldDocH) * docH;
        }
        syncParticleCount();
      }
    });
    bodyObserver.observe(document.body);

    init();
    draw();
  })();
</script>
