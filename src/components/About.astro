---
import config from '../../site.config';

const paragraphs = config.about.text.split('\n\n');
---

<section id="about">
  <p class="section-label"><span>[</span> About <span>]</span></p>
  <div class="about-grid">
    <div class="about-image">
      <img src={config.about.image} alt={`${config.name} at work`} loading="lazy" />
    </div>
    <div class="about-text">
      {paragraphs.map((p) => <p>{p}</p>)}
      <div class="skills-grid">
        {
          config.skills.map((skill) => (
            <div class="skill-group">
              <h4>{skill.label}</h4>
              <p>{skill.items}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    gap: 64px;
    align-items: start;
  }

  .about-image img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border: 1px solid var(--border);
  }

  .about-text p {
    color: var(--text-secondary);
    font-size: 16px;
    line-height: 1.75;
    margin-bottom: 16px;
    text-align: justify;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 32px;
  }

  .skill-group h4 {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .skill-group p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
